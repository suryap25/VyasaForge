# Ignore everything by default.
*

# Keep repository control files.
!.gitignore
!README.md
!ROADMAP.md
!pyproject.toml
!LICENSE
!CONTRIBUTING.md
!SECURITY.md
!CODE_OF_CONDUCT.md
!CHANGELOG.md
!docs/
!docs/**
!.github/
!.github/**

# Keep source, configuration, and prompts.
!src/
!src/**
!configs/
!configs/.gitkeep
!configs/*.example.json
!configs/providers.yaml
!configs/handbook.yaml
!prompts/
!prompts/**

# Ignore generated handbook artifacts.
handbooks/
chapters/
reviews/
reports/
diagrams/
sketchnotes/
output/
logs/
state/
usage_logs/
configs/active-handbook.txt

# Ignore local notes and secrets.
developers_notes.txt
.env
.env.*
!.env.example

# Ignore Python caches, virtual environments, and build outputs.
**/__pycache__/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/
env/
dist/
build/
*.egg-info/

# Ignore editor and OS noise.
.DS_Store
Thumbs.db
.idea/
.vscode/
